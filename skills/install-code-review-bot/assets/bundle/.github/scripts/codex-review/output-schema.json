{
  "type": "object",
  "properties": {
    "review_markdown": {
      "type": "string",
      "description": "The full code review in markdown format"
    },
    "inline_comments": {
      "type": "array",
      "description": "Inline comments anchored to specific diff lines. Only include when confident the line is in the diff.",
      "items": {
        "type": "object",
        "properties": {
          "issue_id": { "type": "string", "description": "Must match an id in state.open_issues" },
          "file": { "type": "string", "description": "Exact file path as it appears in the diff" },
          "line": { "type": "integer", "description": "End line number in the new file version" },
          "start_line": {
            "type": ["integer", "null"],
            "description": "Required key. Start line for a multi-line range (must be < line), or null for single-line comments."
          },
          "title": { "type": "string" },
          "body": {
            "type": "string",
            "description": "Detailed explanation for the inline comment"
          },
          "category": { "type": "string" },
          "suggestion": {
            "type": ["string", "null"],
            "description": "Required key. Replacement code for a GitHub suggestion block, or null when no suggestion is available."
          }
        },
        "required": [
          "issue_id",
          "file",
          "line",
          "start_line",
          "title",
          "body",
          "category",
          "suggestion"
        ],
        "additionalProperties": false
      }
    },
    "state": {
      "type": "object",
      "description": "Machine-readable state for review continuity across runs",
      "properties": {
        "schema_version": { "type": "integer" },
        "last_reviewed_head_sha": { "type": "string" },
        "review_count": { "type": "integer" },
        "updated_at": { "type": "string" },
        "open_issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "severity": { "type": "string", "enum": ["P0", "P1", "P2"] },
              "category": { "type": "string" },
              "title": { "type": "string" },
              "location": { "type": "string" },
              "status": { "type": "string" },
              "first_seen_head_sha": { "type": "string" },
              "last_seen_head_sha": { "type": "string" }
            },
            "required": [
              "id",
              "severity",
              "title",
              "location",
              "status",
              "category",
              "first_seen_head_sha",
              "last_seen_head_sha"
            ],
            "additionalProperties": false
          }
        },
        "recently_resolved_issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "resolved_in_head_sha": { "type": "string" },
              "resolution": { "type": "string" }
            },
            "required": ["id", "resolved_in_head_sha", "resolution"],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "schema_version",
        "last_reviewed_head_sha",
        "review_count",
        "updated_at",
        "open_issues",
        "recently_resolved_issues"
      ],
      "additionalProperties": false
    }
  },
  "required": ["review_markdown", "inline_comments", "state"],
  "additionalProperties": false
}
